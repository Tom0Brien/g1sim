<mujoco model="g1_29dof scene">
  <include file="g1_raw.xml"/>

  <!-- ── scene statistics (camera framing) ────────────────────────────── -->
  <statistic center="0 0 0.8" extent="1.8"/>

  <!-- ── visual settings ──────────────────────────────────────────────── -->
  <visual>
    <headlight diffuse="0.4 0.4 0.45" ambient="0.15 0.15 0.18" specular="0.3 0.3 0.3"/>
    <rgba haze="0.12 0.18 0.28 1"/>
    <global azimuth="150" elevation="-18" offwidth="1920" offheight="1080"/>
    <quality shadowsize="4096"/>
    <map znear="0.01" zfar="50" fogstart="4" fogend="12"/>
  </visual>

  <!-- ── assets: skybox, floor, accent ────────────────────────────────── -->
  <asset>
    <!-- deep blue-to-black gradient skybox -->
    <texture type="skybox" builtin="gradient"
      rgb1="0.35 0.50 0.75" rgb2="0.04 0.04 0.10"
      width="512" height="3072"/>

    <!-- subtle dark checker floor -->
    <texture type="2d" name="floor_tex" builtin="checker" mark="edge"
      rgb1="0.18 0.22 0.28" rgb2="0.12 0.15 0.20"
      markrgb="0.25 0.30 0.38"
      width="512" height="512"/>
    <material name="floor_mat" texture="floor_tex"
      texuniform="true" texrepeat="8 8"
      reflectance="0.15" specular="0.3" shininess="0.5"
      rgba="1 1 1 1"/>
  </asset>

  <!-- ── world geometry ───────────────────────────────────────────────── -->
  <worldbody>
    <!-- ground plane -->
    <geom name="floor" type="plane" size="6 6 0.05"
      material="floor_mat" contype="1" conaffinity="1"/>

    <!-- decorative ring around the robot (non-colliding) -->
    <geom name="ring" type="cylinder" size="1.2 0.003"
      pos="0 0 0.001" material="accent"
      contype="0" conaffinity="0" group="2"/>

    <!-- ── three-point lighting rig ─────────────────────────────────── -->

    <!-- key light: warm, from front-right above -->
    <light name="key" pos="2 -2 4" dir="-0.4 0.4 -0.8"
      diffuse="0.65 0.60 0.55" specular="0.8 0.75 0.7"
      directional="true" castshadow="true"/>

    <!-- fill light: cool, soft, from left -->
    <light name="fill" pos="-3 1 3" dir="0.5 -0.2 -0.7"
      diffuse="0.20 0.25 0.35" specular="0.1 0.1 0.15"
      directional="true" castshadow="false"/>

    <!-- back/rim light: subtle highlight from behind -->
    <light name="rim" pos="-1 3 3" dir="0.2 -0.6 -0.5"
      diffuse="0.18 0.18 0.25" specular="0.3 0.3 0.4"
      directional="true" castshadow="false"/>

    <!-- subtle ground bounce fill -->
    <light name="bounce" pos="0 0 0.1" dir="0 0 1"
      diffuse="0.06 0.06 0.08" specular="0 0 0"
      directional="true" castshadow="false"/>
  </worldbody>
</mujoco>
